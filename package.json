{
  "name": "magento-di-lsp",
  "version": "0.1.0",
  "description": "LSP server for navigating Magento 2 di.xml declarations",
  "bin": {
    "magento-di-lsp": "./bin/magento-di-lsp"
  },
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "sax": "^1.4.0",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.0",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sax": "^1.2.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "bin/"
  ]
}
